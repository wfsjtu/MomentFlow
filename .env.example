# ==========================================
# MomentFlow 项目环境变量示例
# ==========================================
# 复制此文件为 .env，并填入实际配置值
# 注意：.env 文件包含敏感信息，不要提交到 Git！
# ==========================================

# ==========================================
# PostgreSQL 数据库配置
# ==========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/momentflow?schema=public"

# ==========================================
# Redis 缓存配置
# ==========================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ==========================================
# NestJS 后端配置
# ==========================================
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="*"

# ==========================================
# AI 服务配置 (Doubao-Seed-2.0-lite)
# ==========================================
AI_SERVICE_URL="http://localhost:8001"
DOUBAO_MODEL="Doubao-Seed-2.0-lite"
DOUBAO_EP="your-doubao-ep-here"
DOUBAO_API_KEY="your-doubao-api-key-here"

# ==========================================
# 其他配置
# ==========================================
LOG_LEVEL="info"
